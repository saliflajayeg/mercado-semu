# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored — never commit real keys.

# Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase → Settings → API → service_role key (server-only, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp number used for the "Chatear por WhatsApp" deep link, international format, digits only
NEXT_PUBLIC_WHATSAPP_NUMBER=240000000000

NEXT_PUBLIC_MUNIDINERO_NUMBER=
NEXT_PUBLIC_MUNIDINERO_NAME=
